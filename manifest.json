{
  "manifest_version": 3,
  "name": "GitShare Terminal Panel",
  "version": "3.0.0",
  "description": "A live syntax-highlighted side-panel viewer for code snippets and highlighted text.",
  "permissions": [
    "activeTab",
    "sidePanel",
    "contextMenus",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open GitShare Terminal"
  }
}
